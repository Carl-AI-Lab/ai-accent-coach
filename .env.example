# ── LLM (required) ──────────────────────────────────────────
# Any OpenAI-compatible API. Examples:
#   OpenAI      → https://api.openai.com/v1
#   DeepSeek    → https://api.deepseek.com/v1
#   Ollama      → http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4.1-mini

# ── Whisper STT ─────────────────────────────────────────────
# "cuda" for GPU (needs NVIDIA drivers + cuBLAS + cuDNN)
# "cpu"  for CPU-only (no GPU required, ~11x slower)
WHISPER_DEVICE=cuda
# Model: distil-large-v3 | large-v3 | medium | small | base | tiny
WHISPER_MODEL=distil-large-v3
# Auto-unload model from memory after N seconds of idle (saves GPU VRAM)
WHISPER_UNLOAD_TIMEOUT=120

# ── TTS ─────────────────────────────────────────────────────
TTS_VOICE=en-US-AndrewMultilingualNeural

# ── Server ──────────────────────────────────────────────────
PORT=8443

# ── Optional ────────────────────────────────────────────────
# HuggingFace mirror for China mainland users
# HF_ENDPOINT=https://hf-mirror.com
# Lookup cache TTL in seconds (default 12h)
# LOOKUP_CACHE_TTL_SECONDS=43200
